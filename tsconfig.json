{
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "strict": true,
        "alwaysStrict": true,
        "sourceMap": true,
        "removeComments": true,
        "resolveJsonModule": true,
        "noUnusedLocals": true,
        "types": ["node"]
    }
}